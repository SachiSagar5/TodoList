{
  "name": "taskmaster",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "vite build --mode electron",
    "build:mac": "vite build --mode electron && electron-builder --mac --config",
    "build:mac:arm": "vite build --mode electron && electron-builder --mac --arm64 --config",
    "build:apk": "vite build && npx cap sync android && cd android && ./gradlew assembleDebug && cd ..",
    "build:apk:linux": "vite build && npx cap sync android && (cd android && chmod +x gradlew && ./gradlew assembleDebug)"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0"
  },
  "build": {
    "appId": "com.taskmaster.app",
    "productName": "TaskMaster",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "TaskMaster",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  }
}
