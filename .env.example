VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# AI Note Writing
# Uses Hugging Face free inference API first (no key needed, but rate-limited).
# For better performance set HUGGINGFACE_API_KEY (free tier at hf.co/settings/tokens).
# Falls back to Ollama (local free AI) if Hugging Face fails.
# Install Ollama: https://ollama.com (brew install ollama && ollama pull llama3.2)
# AI_MODEL=llama3.2
# OLLAMA_URL=http://localhost:11434
# HUGGINGFACE_API_KEY=your-huggingface-api-key
# HF_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
